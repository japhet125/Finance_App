<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F7FA">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <ImageButton
            android:id="@+id/btnMenu"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_gravity="end"
            android:background="@android:color/transparent"
            android:src="@android:drawable/ic_menu_sort_by_size"
            android:contentDescription="Menu" />

        <TextView
            android:id="@+id/txtWelcome"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Welcome"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="#0B1F3A"
            android:layout_marginBottom="24dp" />

        <TextView
            android:id="@+id/txtCreditScore"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="💳 Credit Score\n500"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:background="#0B1F3A"
            android:padding="22dp"
            android:layout_marginBottom="16dp" />
        <TextView
            android:id="@+id/txtAutoPayTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🌳 Auto Pay"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginTop="16dp" />

        <TextView
            android:id="@+id/txtAutoPayStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Status:"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/txtAutoPayNextDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Next Payment:"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/txtAutoPayAmount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Amount:"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/txtTotalRequested"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="💰 Total Requested\n$0"
            android:textSize="18sp"
            android:textStyle="bold"
            android:background="#FFFFFF"
            android:padding="20dp"
            android:layout_marginBottom="12dp" />

        <TextView
            android:id="@+id/txtPendingLoans"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="⏳ Pending Requests\n0"
            android:textSize="18sp"
            android:textStyle="bold"
            android:background="#FFFFFF"
            android:padding="20dp"
            android:layout_marginBottom="12dp" />

        <TextView
            android:id="@+id/txtApprovedAmount"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="✅ Approved Amount\n$0"
            android:textSize="18sp"
            android:textStyle="bold"
            android:background="#FFFFFF"
            android:padding="20dp"
            android:layout_marginBottom="12dp" />

        <TextView
            android:id="@+id/txtRejectedLoans"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="❌ Rejected Requests\n0"
            android:textSize="18sp"
            android:textStyle="bold"
            android:background="#FFFFFF"
            android:padding="20dp"
            android:layout_marginBottom="12dp" />

        <TextView
            android:id="@+id/txtUnreadNotifications"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🔔 Unread Notifications\n0"
            android:textSize="18sp"
            android:textStyle="bold"
            android:background="#FFFFFF"
            android:padding="20dp"
            android:layout_marginBottom="12dp" />

    </LinearLayout>
</ScrollView>