<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F7FA">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <Button
            android:id="@+id/btnBack"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Back" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Admin Analytics"
            android:textSize="30sp"
            android:textStyle="bold"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="24dp" />

        <TextView
            android:id="@+id/txtTotalUsers"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="👥 Total Users: 0"
            android:textSize="18sp"
            android:textStyle="bold"
            android:background="#FFFFFF"
            android:padding="20dp"
            android:layout_marginBottom="12dp" />

        <TextView
            android:id="@+id/txtTotalLoans"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📄 Total Loans: 0"
            android:textSize="18sp"
            android:textStyle="bold"
            android:background="#FFFFFF"
            android:padding="20dp"
            android:layout_marginTop="12dp" />

        <TextView
            android:id="@+id/txtApprovedLoans"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text= "✅ Approved Loans: 0"
            android:textSize="18sp"
            android:textStyle="bold"
            android:background="#FFFFFF"
            android:padding="20dp"
            android:layout_marginTop="12dp" />

        <TextView
            android:id="@+id/txtOverdueLoans"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⚠️ Overdue Loans: 0"
            android:textSize="18sp"
            android:textStyle="bold"
            android:background="#FFFFFF"
            android:padding="20dp"
            android:layout_marginTop="12dp" />

        <TextView
            android:id="@+id/txtTotalLoaned"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="💰 Total Money Loaned: $0"
            android:textSize="18sp"
            android:textStyle="bold"
            android:background="#FFFFFF"
            android:padding="20dp"
            android:layout_marginTop="12dp" />

        <TextView
            android:id="@+id/txtTotalPayments"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text= "💵 Total Payments Received: $0"
            android:textSize="18sp"
            android:textStyle="bold"
            android:background="#FFFFFF"
            android:padding="20dp"
            android:layout_marginTop="12dp" />

        <TextView
            android:id="@+id/txtAverageCredit"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⭐ Average Credit Score: 0"
            android:textSize="18sp"
            android:textStyle="bold"
            android:background="#FFFFFF"
            android:padding="20dp"
            android:layout_marginTop="12dp" />

    </LinearLayout>
</ScrollView>