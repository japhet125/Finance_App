<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F7FA">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <Button
            android:id="@+id/btnBack"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Back"/>

        <TextView
            android:id="@+id/txtUserName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="24sp"
            android:textStyle="bold"
            android:layout_marginTop="16dp"/>

        <TextView
            android:id="@+id/txtUserEmail"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>

        <TextView
            android:id="@+id/txtUserPhone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>

        <TextView
            android:id="@+id/txtUserAddress"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>

        <TextView
            android:id="@+id/txtUserRole"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>

        <TextView
            android:id="@+id/txtUserCredit"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>

        <TextView
            android:id="@+id/txtUserIdentity"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>
        <TextView
            android:id="@+id/txtAccountStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Account Status: Active"
            android:textStyle="bold"
            android:textSize="18sp" />

        <TextView
            android:id="@+id/txtTotalLoans"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"/>

        <TextView
            android:id="@+id/txtOutstandingBalance"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>
        <Button
            android:id="@+id/btnSuspendUser"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Suspend User"
            android:layout_marginTop="24dp" />

        <Button
            android:id="@+id/btnReactivateUser"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Reactivate User"
            android:layout_marginTop="12dp" />
        <Button
            android:id="@+id/btnViewUserLoans"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="View User Loans"
            android:layout_marginTop="16dp" />
        <Button
            android:id="@+id/btnPromoteAdmin"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Promote to Admin"
            android:layout_marginTop="16dp" />

        <Button
            android:id="@+id/btnDemoteUser"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Demote to User"
            android:layout_marginTop="12dp" />
        <Button
            android:id="@+id/btnViewUserTransactions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="View User Transactions"
            android:layout_marginTop="12dp" />

    </LinearLayout>

</ScrollView>