<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp"
    android:layout_marginBottom="12dp"
    android:background="#EEEEEE">

    <TextView
        android:id="@+id/txtPaymentLoanAmount"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="20sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/txtPaymentLoanReason"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content" />

    <TextView
        android:id="@+id/txtPaymentLoanPlan"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content" />

    <TextView
        android:id="@+id/txtPaymentLoanBalance"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textStyle="bold" />

    <EditText
        android:id="@+id/etPayAmount"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Enter payment amount"
        android:inputType="numberDecimal"
        android:layout_marginTop="12dp" />

    <Button
        android:id="@+id/btnPayLoan"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Pay This Loan"
        android:layout_marginTop="12dp" />

</LinearLayout>