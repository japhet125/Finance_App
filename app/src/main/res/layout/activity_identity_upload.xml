<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F7FA">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <Button
            android:id="@+id/btnBack"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Back" />

        <TextView
            android:id="@+id/txtIdentityTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Identity Verification"
            android:textSize="28sp"
            android:textStyle="bold"
            android:layout_marginTop="24dp" />

        <Spinner
            android:id="@+id/spIdType"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="24dp" />

        <EditText
            android:id="@+id/etIdNumber"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="12dp"
            android:hint="ID Number" />

        <EditText
            android:id="@+id/etIdExpiration"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="12dp"
            android:hint="Expiration Date MM/DD/YYYY" />

        <Spinner
            android:id="@+id/spIdCountry"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="12dp" />

        <Button
            android:id="@+id/btnUploadIdPicture"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Choose ID Picture"
            android:layout_marginTop="16dp" />
        <ImageView
            android:id="@+id/imgIdPreview"
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:scaleType="centerCrop"
            android:layout_marginTop="12dp" />

        <Button
            android:id="@+id/btnSubmitIdentity"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Submit Verification"
            android:layout_marginTop="24dp" />

    </LinearLayout>
</ScrollView>