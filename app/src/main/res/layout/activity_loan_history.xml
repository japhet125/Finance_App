<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">
    <Button
        android:id="@+id/btnBack"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Back"
        android:layout_marginBottom="16dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Loan History"
        android:textSize="28sp"
        android:textStyle="bold"
        android:layout_marginBottom="16dp"/>
    <Button
        android:id="@+id/btnDownloadStatement"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Download Statement"
        android:layout_marginTop="8dp"/>

    <EditText
        android:id="@+id/etLoanSearch"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginBottom="12dp"
        android:hint="Search by reason"
        android:inputType="text" />

    <Spinner
        android:id="@+id/spinnerLoanSort"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginBottom="12dp" />

    <Spinner
        android:id="@+id/spinnerLoanFilter"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginBottom="16dp" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerLoans"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"/>

</LinearLayout>