<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#FFFFFF"
    android:padding="18dp"
    android:layout_marginBottom="12dp">

    <TextView
        android:id="@+id/txtPaymentUserId"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Customer:"
        android:textStyle="bold"
        android:textSize="15sp" />

    <TextView
        android:id="@+id/txtPaymentLoanId"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Loan ID:"
        android:textSize="15sp"
        android:layout_marginTop="6dp" />

    <TextView
        android:id="@+id/txtPaymentAmount"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Payment Amount:"
        android:textSize="16sp"
        android:textStyle="bold"
        android:layout_marginTop="6dp" />

    <TextView
        android:id="@+id/txtPaymentBalance"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Balance:"
        android:textSize="15sp"
        android:layout_marginTop="6dp" />

    <TextView
        android:id="@+id/txtPaymentDate"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Submitted:"
        android:textSize="14sp"
        android:layout_marginTop="6dp" />

    <Button
        android:id="@+id/btnApprovePayment"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Approve Payment"
        android:layout_marginTop="12dp" />

    <Button
        android:id="@+id/btnRejectPayment"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Reject Payment"
        android:layout_marginTop="8dp" />

</LinearLayout>